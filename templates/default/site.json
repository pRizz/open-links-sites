{
  "$schema": "https://open-links.dev/schema/site.schema.json",
  "title": "__SITE_TITLE__",
  "description": "__SITE_DESCRIPTION__",
  "baseUrl": "/__PERSON_ID__/",
  "theme": {
    "active": "sleek",
    "available": ["sleek", "daybreak", "sleek-emerald", "sleek-mono"]
  },
  "ui": {
    "compositionMode": "balanced",
    "groupingStyle": "subtle",
